# Django Configuration
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key
DEBUG=True

# Database Configuration (Django Native / PostgreSQL)
# Example: postgresql://user:password@localhost:5432/kaku_db
# Leave empty to use local SQLite for development
DATABASE_URL=

# Email Configuration (Optional - falls back gracefully if missing)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your_sendgrid_api_key_or_app_password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
